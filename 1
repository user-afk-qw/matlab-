% ЛАБОРАТОРНАЯ РАБОТА №4
% Тема: Операции с векторами и матрицами. Линейная алгебра.

% 1. Формирование специальных матриц (Раздел 4.1)
% Задача: Создать различные типы матриц и изучить их размерность
disp('--- Задача 1: Специальные матрицы ---');
A_eye = eye(4);            % Единичная матрица 4x4
A_zeros = zeros(2, 3);     % Нулевая матрица 2x3
A_ones = ones(3, 2);       % Матрица из единиц 3x2
A_rand = rand(3);          % Матрица случайных чисел (равномерное распределение) 3x3
A_randn = randn(3);        % Матрица со случайными числами (нормальное распределение)

disp('Единичная матрица:'); disp(A_eye);
disp('Размерность случайной матрицы:'); disp(size(A_rand));

% 2. Матричные операции и функции (Раздел 4.4)
% Задача: Вычислить основные характеристики матрицы
disp('--- Задача 2: Характеристики матрицы ---');
M = [1 2 3; 4 5 6; 7 8 0];

d = det(M);                % Определитель (детерминант)
tr = trace(M);             % След матрицы (сумма диагональных элементов)
r = rank(M);               % Ранг матрицы
m_inv = inv(M);            % Обратная матрица

disp(['Определитель: ', num2str(d)]);
disp(['Ранг: ', num2str(r)]);
disp('Обратная матрица:'); disp(m_inv);

% 3. Решение систем линейных алгебраических уравнений (СЛАУ) (Раздел 4.4.9)
% Задача: Решить систему Ax = B двумя способами и сравнить точность
disp('--- Задача 3: Решение СЛАУ ---');
% Система:
% 2x + y + z = 4
% x + 3y + 2z = 5
% x + y + 4z = 6
A = [2 1 1; 1 3 2; 1 1 4];
B = [4; 5; 6];

% Способ 1: Использование обратной матрицы (менее эффективно)
x1 = inv(A) * B;

% Способ 2: Оператор обратного деления \ (рекомендуемый в MATLAB)
x2 = A \ B;

disp('Решение x1 (inv):'); disp(x1');
disp('Решение x2 (оператор \):'); disp(x2');

% Проверка невязки (ошибки): A*x - B
residual = norm(A*x2 - B);
disp(['Норма невязки (ошибка решения): ', num2str(residual)]);

% 4. Работа с полиномами через векторы (Раздел 4.6)
% Задача: Найти корни полинома и значение в точке
disp('--- Задача 4: Полиномы ---');
% Полином: x^3 - 6x^2 + 11x - 6
p = [1 -6 11 -6];

roots_p = roots(p);        % Поиск корней
val_2 = polyval(p, 2);     % Значение полинома в точке x=2
p_der = polyder(p);        % Производная полинома (коэффициенты)

disp('Корни полинома:'); disp(roots_p');
disp(['Значение в x=2: ', num2str(val_2)]);
disp('Коэффициенты производной:'); disp(p_der);

