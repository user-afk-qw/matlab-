% ЛАБОРАТОРНАЯ РАБОТА №6
% Тема: Графические средства системы MATLAB. Двумерная графика.

% 1. Построение простых графиков и оформление (Раздел 6.1)
% Задача: Построить график функции sin(x)/x и добавить подписи
disp('--- Задача 1: Оформление графика ---');
x = -10:0.1:10;
y = sin(x) ./ (x + eps); % eps добавлен, чтобы избежать деления на 0

figure('Name', 'Основы графики');
plot(x, y, 'LineWidth', 2);
grid on; % Включение сетки
xlabel('Ось X'); 
ylabel('Ось Y');
title('График функции sinc(x)');

% 2. Несколько графиков в одном окне (Раздел 6.2.1)
% Задача: Сравнить функции sin(x) и cos(x) на одном графике
disp('--- Задача 2: Несколько кривых ---');
x2 = 0:0.05:2*pi;
y1 = sin(x2);
y2 = cos(x2);

figure('Name', 'Сравнение функций');
% 'r--' - красная пунктирная линия, 'b-' - синяя сплошная
plot(x2, y1, 'r--', x2, y2, 'b-', 'LineWidth', 1.5);
legend('sin(x)', 'cos(x)'); % Легенда для различения кривых
title('Синус и Косинус');

% 3. Работа с подокнами (Раздел 6.2.5)
% Задача: Разделить графическое окно на несколько частей
disp('--- Задача 3: Использование subplot ---');
figure('Name', 'Раздельные окна');

% Верхнее подокно (2 строки, 1 столбец, позиция 1)
subplot(2, 1, 1);
plot(x2, sin(x2.^2));
title('sin(x^2)');
grid on;

% Нижнее подокно (2 строки, 1 столбец, позиция 2)
subplot(2, 1, 2);
plot(x2, cos(exp(x2/2)));
title('cos(e^{x/2})');
grid on;

% 4. Специальные виды графиков (Раздел 6.3)
% Задача: Построить ступенчатый график и график с заполнением
disp('--- Задача 4: Спецграфики ---');
xs = 0:0.5:10;
ys = sqrt(xs);

figure('Name', 'Специальные графики');
subplot(1, 2, 1);
stairs(xs, ys, 'LineWidth', 2); % Ступенчатый график
title('stairs (Ступенчатый)');
subplot(1, 2, 2);
fill(xs, ys, 'g'); % График с заливкой области
title('fill (С заполнением)');

% ЛАБОРАТОРНАЯ РАБОТА №7
% Тема: Трехмерная графика и визуализация поверхностей.

% 1. Сетчатые графики и создание сетки координат (Раздел 7.1)
% Задача: Построить «каркасную» поверхность функции sinc(r)
disp('--- Задача 1: Построение сетчатой поверхности (mesh) ---');
[X, Y] = meshgrid(-8 : 0.5 : 8, -8 : 0.5 : 8); % Создание координатной сетки
R = sqrt(X.^2 + Y.^2) + eps;
Z = sin(R) ./ R;

figure('Name', 'Сетчатый график');
mesh(X, Y, Z); % Построение каркаса
grid on;
xlabel('X'); ylabel('Y'); zlabel('Z');
title('Сетчатый график функции sinc(r)');

% 2. Поверхности с заливкой и цветовые карты (Раздел 7.2)
% Задача: Построить залитую поверхность с интерполяцией цветов
disp('--- Задача 2: Поверхность с заливкой (surf) ---');
figure('Name', 'Залитая поверхность');
surf(X, Y, Z); % Построение поверхности с заливкой граней
shading interp; % Плавный переход цветов между узлами сетки
colorbar; % Вывод шкалы соответствия цвета и высоты Z
colormap(jet); % Установка стандартной цветовой схемы
title('Поверхность с интерполяцией цветов (surf + shading)');

% 3. Освещение и комбинированные графики (Раздел 7.3)
% Задача: Построить поверхность с имитацией источника света и контурным графиком
disp('--- Задача 3: Освещение и контуры ---');
[X2, Y2, Z2] = peaks(30); % Использование встроенной тестовой функции "Пики"

figure('Name', 'Сложная визуализация');
% surfl добавляет эффект отраженного света (L - lighting)
subplot(1, 2, 1);
surfl(X2, Y2, Z2); 
shading interp; colormap(copper); % "Медный" вид поверхности
title('Освещенная поверхность (surfl)');

% meshc строит сетку и под ней проекции линий уровня (C - contour)
subplot(1, 2, 2);
meshc(X2, Y2, Z2); 
title('Сетка с проекцией уровней (meshc)');

% 4. Линии равного уровня (Контуры) (Раздел 7.4)
% Задача: Отобразить рельеф в виде плоской топографической карты
disp('--- Задача 4: Контурный график ---');
figure('Name', 'Топография');
contourf(X2, Y2, Z2, 20); % f - заполненные цветом контуры (filled)
colorbar;
title('Контурный график (вид сверху)');
