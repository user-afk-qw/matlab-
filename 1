% ЛАБОРАТОРНАЯ РАБОТА №3
% Тема: Программные средства математических вычислений

% 1. Работа с комплексными числами (Раздел 3.5)
% Задача: Представить комплексное число в разных формах и проверить сопряжение
disp('--- Задача 1: Комплексные числа ---');
z1 = 3 + 4i;
z2 = 1 - 2j;

% Вычисление модуля и аргумента (фазы)
r = abs(z1);
phi = angle(z1); % в радианах
disp(['Число z1: ', num2str(z1)]);
disp(['Модуль z1: ', num2str(r)]);
disp(['Фаза z1 (град): ', num2str(phi * 180/pi)]);

% Операции сопряжения и проверка: z * conj(z) = abs(z)^2
check_val = z1 * conj(z1);
disp(['Проверка z*conj(z): ', num2str(check_val), ' (должно быть ', num2str(r^2), ')']);

% 2. Элементарные функции и точность (Раздел 3.4)
% Задача: Проверить тригонометрические тождества для векторов
disp('--- Задача 2: Векторные вычисления ---');
x = [0, pi/4, pi/2, pi];
y_sin = sin(x);
y_cos = cos(x);

% Проверка основного тождества sin^2 + cos^2 = 1
identity_check = y_sin.^2 + y_cos.^2;
disp('Проверка sin^2 + cos^2 для вектора x:');
disp(identity_check);

% 3. Функции округления и остатка (Раздел 3.7)
% Задача: Продемонстрировать разницу между типами округления
disp('--- Задача 3: Округление ---');
vals = [-1.9, -1.1, 1.1, 1.9];
disp('Исходные числа:'); disp(vals);
disp('Округление до ближайшего (round):'); disp(round(vals));
disp('Округление к нулю (fix):'); disp(fix(vals));
disp('Округление к меньшему (floor):'); disp(floor(vals));
disp('Округление к большему (ceil):'); disp(ceil(vals));

% 4. Анализ бесконечности и неопределенности (Раздел 3.2)
disp('--- Задача 4: Спецзначения ---');
inf_val = 1/0;    % Inf
